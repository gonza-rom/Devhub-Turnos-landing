<script is:inline>
  // Nav scroll
  const nav=document.getElementById("nav");
  window.addEventListener("scroll",()=>nav?.classList.toggle("sc",window.scrollY>40));

  // Mobile menu
  const hbg=document.getElementById("hbg"),mm=document.getElementById("mm");
  hbg?.addEventListener("click",()=>{mm?.classList.toggle("op");hbg?.classList.toggle("act")});
  document.querySelectorAll(".ml,.mcta").forEach(el=>el.addEventListener("click",()=>{mm?.classList.remove("op");hbg?.classList.remove("act")}));

  // Scroll reveal
  const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add("in")}),{threshold:.1});
  document.querySelectorAll(".fc,.dc,.plan,.rc,.val,.faq-item").forEach(el=>{el.classList.add("rv");io.observe(el)});

  // Toggle facturación mensual/anual
  const toggle = document.getElementById("billing-toggle");
  const proPrice = document.getElementById("pro-price");
  const proDur = document.getElementById("pro-dur");
  const proAhorro = document.getElementById("pro-ahorro");
  const tlM = document.getElementById("tlabel-m");
  const tlA = document.getElementById("tlabel-a");
  let anual = false;

  const PRECIO_MES = 35000;
  const PRECIO_ANUAL = Math.round(PRECIO_MES * 12 * 0.8);
  const PRECIO_ANUAL_MES = Math.round(PRECIO_MES * 0.8);

  toggle?.addEventListener("click", () => {
    anual = !anual;
    toggle.classList.toggle("on", anual);
    tlM.style.opacity = anual ? "0.4" : "1";
    tlA.style.opacity = anual ? "1" : "0.4";
    if (anual) {
      proPrice.textContent = `$${PRECIO_ANUAL_MES.toLocaleString("es-AR")}`;
      proDur.textContent = "/mes · facturado anual";
      proAhorro.style.display = "block";
    } else {
      proPrice.textContent = `$${PRECIO_MES.toLocaleString("es-AR")}`;
      proDur.textContent = "/mes";
      proAhorro.style.display = "none";
    }
  });

  // FAQ accordion
  document.querySelectorAll(".faq-item").forEach(item => {
    item.addEventListener("click", () => {
      const isOpen = item.classList.contains("open");
      document.querySelectorAll(".faq-item").forEach(i => i.classList.remove("open"));
      if (!isOpen) item.classList.add("open");
    });
  });
</script>

<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{--b:#2563eb;--bd:#1d4ed8;--bl:#3b82f6;--bdim:rgba(37,99,235,.1);--bk:#06060f;--s1:#0b0b18;--s2:#10101f;--s3:#16162a;--fg:#f0f0f8;--fg2:#8888aa;--fg3:#44445a;--H:'Syne',sans-serif;--B:'DM Sans',sans-serif}
html{scroll-behavior:smooth}
body{background:var(--bk);color:var(--fg);font-family:var(--B);font-weight:300;line-height:1.65;overflow-x:hidden}
.C{max-width:1200px;margin:0 auto;padding:0 2rem}

/* NAV */
nav{position:fixed;top:0;left:0;right:0;z-index:100;transition:background .3s,border-color .3s;border-bottom:1px solid transparent}
nav.sc{background:rgba(6,6,15,.95);backdrop-filter:blur(18px);border-color:rgba(255,255,255,.05)}
.nav-in{max-width:1200px;margin:0 auto;padding:0 2rem;height:68px;display:flex;align-items:center;justify-content:space-between}
.logo{height:34px;width:auto;object-fit:contain}
.nav-links{display:flex;align-items:center;gap:1.75rem}
.nav-links a{font-size:.875rem;font-weight:500;color:var(--fg2);text-decoration:none;transition:color .2s}
.nav-links a:hover{color:var(--fg)}
.nwa{display:flex!important;align-items:center;gap:5px;color:#16a34a!important}
.ncta{background:var(--b)!important;color:#fff!important;padding:8px 20px!important;border-radius:8px!important;font-weight:600!important}
.ncta:hover{background:var(--bd)!important}
.hbg{display:none;flex-direction:column;gap:5px;background:none;border:none;cursor:pointer;padding:4px}
.hbg span{display:block;width:24px;height:2px;background:var(--fg);border-radius:2px;transition:all .3s}
.hbg.act span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.hbg.act span:nth-child(2){opacity:0}
.hbg.act span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}
.mmenu{position:fixed;top:68px;left:0;right:0;z-index:99;background:rgba(6,6,15,.98);backdrop-filter:blur(20px);padding:1.5rem 2rem;display:flex;flex-direction:column;gap:1rem;border-bottom:1px solid rgba(255,255,255,.05);transform:translateY(-110%);opacity:0;transition:transform .3s,opacity .3s;pointer-events:none}
.mmenu.op{transform:translateY(0);opacity:1;pointer-events:all}
.ml{font-size:1rem;color:var(--fg2);text-decoration:none;padding:.5rem 0;border-bottom:1px solid rgba(255,255,255,.04);transition:color .2s}
.ml:hover{color:var(--fg)}
.mcta{display:inline-flex;align-items:center;justify-content:center;background:var(--b);color:#fff;padding:12px 24px;border-radius:8px;font-weight:600;text-decoration:none;margin-top:.5rem}

/* BUTTONS */
.bp{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;border-radius:10px;background:var(--b);color:#fff;font-size:.9375rem;font-weight:600;text-decoration:none;transition:background .2s,transform .15s,box-shadow .2s}
.bp:hover{background:var(--bd);transform:translateY(-2px);box-shadow:0 12px 32px rgba(37,99,235,.35)}
.bl{padding:15px 36px;font-size:1rem}
.bg{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;border-radius:10px;border:1px solid rgba(255,255,255,.12);color:var(--fg2);font-size:.9375rem;font-weight:500;text-decoration:none;transition:border-color .2s,color .2s,background .2s}
.bg:hover{border-color:var(--bl);color:var(--fg);background:var(--bdim)}
.bo{display:inline-flex;align-items:center;gap:7px;padding:11px 24px;border-radius:10px;border:1px solid rgba(255,255,255,.12);color:var(--fg2);font-size:.875rem;font-weight:500;text-decoration:none;transition:all .2s}
.bo:hover{border-color:var(--bl);color:var(--fg);background:var(--bdim)}
.bwa{display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:13px 24px;border-radius:10px;background:#16a34a;color:#fff;font-size:.9375rem;font-weight:600;text-decoration:none;transition:background .2s}
.bwa:hover{background:#15803d}
.bwao{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;border-radius:10px;border:1px solid rgba(22,163,74,.3);color:#22c55e;font-size:.9375rem;font-weight:600;text-decoration:none;background:rgba(22,163,74,.06);transition:all .2s}
.bwao:hover{background:rgba(22,163,74,.12);border-color:rgba(22,163,74,.5)}

/* SECTION */
.sec{padding:8rem 0}
.sec.dark{background:var(--s1)}
.sh{margin-bottom:4rem}
.sh.center{text-align:center}
.stag{display:inline-block;font-size:.6875rem;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--bl);margin-bottom:1rem}
.sh2{font-family:var(--H);font-size:clamp(2rem,5vw,3.25rem);font-weight:800;line-height:1.12;color:var(--fg);margin-bottom:1rem}
.sdesc{font-size:1.0625rem;color:var(--fg2);line-height:1.7;max-width:600px;margin:0 auto}
.acc{color:var(--bl)}

/* HERO */
.hero{min-height:100vh;position:relative;overflow:hidden;padding:8rem 2rem 4rem}
.hero-bg{position:absolute;inset:0;z-index:0}
.hgrid{position:absolute;inset:0;background-image:linear-gradient(rgba(37,99,235,.035) 1px,transparent 1px),linear-gradient(90deg,rgba(37,99,235,.035) 1px,transparent 1px);background-size:60px 60px;mask-image:radial-gradient(ellipse 90% 80% at 30% 40%,black,transparent)}
.orb{position:absolute;border-radius:50%;filter:blur(70px)}
.o1{top:-10%;left:-15%;width:700px;height:700px;background:radial-gradient(circle,rgba(37,99,235,.12) 0%,transparent 65%)}
.o2{bottom:-10%;right:5%;width:500px;height:500px;background:radial-gradient(circle,rgba(59,130,246,.07) 0%,transparent 65%)}
.hero-wrap{position:relative;z-index:1;display:flex;align-items:center;gap:5rem}
.hero-l{flex:1;max-width:560px}
.badge{display:inline-flex;align-items:center;gap:8px;font-size:.6875rem;font-weight:600;letter-spacing:.15em;text-transform:uppercase;color:var(--bl);border:1px solid rgba(59,130,246,.25);padding:6px 14px;border-radius:99px;margin-bottom:1.75rem;animation:fu .6s ease both}
.bdot{width:6px;height:6px;border-radius:50%;background:var(--bl);animation:pl 2s ease infinite}
@keyframes pl{0%,100%{opacity:1}50%{opacity:.3}}
.h1{font-family:var(--H);font-size:clamp(2.5rem,5.5vw,4rem);font-weight:800;line-height:1.1;color:var(--fg);margin-bottom:1.5rem;animation:fu .6s .1s ease both}
