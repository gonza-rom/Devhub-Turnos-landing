---
const WA_URL  = "https://wa.me/543834944727?text=Hola!%20Quiero%20saber%20m%C3%A1s%20sobre%20DevHub%20Turnos";
const APP_URL = "https://app.turnos.devhub.com.ar";
const SITE    = "https://turnos.devhub.com.ar";

const demos = [
  { nombre: "Detailing / Lavadero",  url: "https://demo-detailing-cta.vercel.app/", desc: "Landing + reserva integrada para negocios de detailing automotriz.", live: true  },
  { nombre: "Barbería / Peluquería", url: "#",                                       desc: "Turnos para barberías con servicios y horarios por estilista.",      live: false },
  { nombre: "Estética / Spa",        url: "#",                                       desc: "Agenda online para centros de estética, masajes y tratamientos.",    live: false },
  { nombre: "Médico / Salud",        url: "#",                                       desc: "Turnos médicos con múltiples profesionales y especialidades.",        live: false },
];

const features = [
  { titulo: "Reservas 24/7",           desc: "Tus clientes reservan cuando quieren, sin llamadas ni mensajes. El sistema gestiona la disponibilidad automáticamente." },
  { titulo: "Notificaciones WhatsApp", desc: "Recibís un mensaje automático al instante cada vez que alguien reserva. Tu cliente también recibe la confirmación." },
  { titulo: "Panel de administración", desc: "Confirmá, cancelá y gestioná todos tus turnos desde un solo lugar. Diseñado para ser simple y rápido." },
  { titulo: "Horarios configurables",  desc: "Definís tus días y franjas horarias. El sistema calcula los slots disponibles automáticamente." },
  { titulo: "Link personalizado",      desc: "Cada negocio tiene su URL propia. La compartís por Instagram, WhatsApp o en tu sitio web." },
  { titulo: "Landing page incluida",   desc: "Creamos el sitio web de tu negocio integrado al sistema de turnos. Todo en un solo lugar." },
];

const faqs = [
  { q: "¿Necesito saber de tecnología para usarlo?",     a: "No. El sistema está diseñado para ser simple desde el primer día. Si podés usar WhatsApp, podés usar DevHub Turnos." },
  { q: "¿Cómo recibo los pagos por los servicios?",      a: "DevHub Turnos gestiona los turnos. Los pagos los cobrás como siempre — en efectivo, transferencia o el método que uses." },
  { q: "¿Puedo cancelar cuando quiero?",                 a: "Sí. Sin contratos ni permanencia. Cancelás cuando querés desde el panel o por WhatsApp." },
  { q: "¿Qué pasa cuando vence el trial de 14 días?",    a: "Te avisamos antes del vencimiento. Si no contratás el plan Pro, el sistema se pausa pero tus datos no se borran." },
  { q: "¿Funciona para negocios con varios empleados?",  a: "Sí. En el plan Pro podés agregar usuarios ilimitados. Cada uno puede gestionar los turnos desde su cuenta." },
  { q: "¿Puedo tener mi propio dominio?",                a: "Sí, en el plan Enterprise configuramos tu dominio personalizado. En Pro tenés una URL del tipo reservas.devhub.com.ar/tu-negocio." },
];
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="DevHub Turnos — Sistema de turnos online para negocios. Reservas 24/7, notificaciones por WhatsApp y panel de administración. Probá gratis 14 días."/>
  <meta property="og:title" content="DevHub Turnos — Turnos online para tu negocio"/>
  <meta property="og:description" content="Tus clientes reservan solos. Vos gestionás todo desde un panel simple. Probá gratis 14 días."/>
  <meta property="og:image" content={`${SITE}/devhub-turnos-logo.png`}/>
  <meta property="og:url" content={SITE}/>
  <meta property="og:type" content="website"/>
  <meta name="twitter:card" content="summary_large_image"/>
  <link rel="icon" type="image/png" href="/devhub-turnos-logo.png"/>
  <title>DevHub Turnos — Sistema de turnos online</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500;9..40,600&display=swap" rel="stylesheet"/>
</head>
<body>

<!-- NAV -->
<nav id="nav">
  <div class="nav-in">
    <a href="/" class="nav-logo"><img src="/devhub-turnos.png" alt="DevHub Turnos" class="logo"/></a>
    <div class="nav-links">
      <a href="#funciones">Funciones</a>
      <a href="#demos">Demos</a>
      <a href="#planes">Planes</a>
      <a href="#nosotros">Nosotros</a>
      <a href="#faq">FAQ</a>
      <a href={WA_URL} target="_blank" class="nwa">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.856L.054 23.285a.75.75 0 0 0 .921.921l5.43-1.478A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.693-.503-5.235-1.382l-.374-.217-3.876 1.054 1.054-3.876-.217-.374A9.953 9.953 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        WhatsApp
      </a>
      <a href={APP_URL} target="_blank" class="ncta">Probá gratis</a>
    </div>
    <button class="hbg" id="hbg"><span></span><span></span><span></span></button>
  </div>
</nav>
<div class="mmenu" id="mm">
  <a href="#funciones" class="ml">Funciones</a>
  <a href="#demos" class="ml">Demos</a>
  <a href="#planes" class="ml">Planes</a>
  <a href="#nosotros" class="ml">Nosotros</a>
  <a href="#faq" class="ml">FAQ</a>
  <a href={WA_URL} target="_blank" class="ml">WhatsApp</a>
  <a href={APP_URL} target="_blank" class="mcta">Probá gratis — 14 días</a>
</div>

<!-- HERO -->
<section class="hero">
  <div class="hero-bg"><div class="hgrid"></div><div class="orb o1"></div><div class="orb o2"></div></div>
  <div class="C hero-wrap">
    <div class="hero-l">
      <div class="badge"><span class="bdot"></span>Sistema de turnos para negocios · Argentina</div>
      <h1 class="h1">Tus clientes<br/>reservan solos.<br/><em>Vos crecés.</em></h1>
      <p class="hero-p">Olvidate de los mensajes preguntando horarios. Con DevHub Turnos tus clientes reservan 24/7 y vos recibís la notificación al instante.</p>
      <div class="hero-btns">
        <a href={APP_URL} target="_blank" class="bp bl">Empezar gratis — 14 días <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
        <a href="#demos" class="bg">Ver demos</a>
      </div>
      <div class="checks">
        <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Sin tarjeta de crédito</span>
        <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Configuración en minutos</span>
        <span><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>Soporte en español</span>
      </div>
    </div>

    <!-- Screenshot real del sistema -->
    <div class="hero-r">
      <div class="screenshot-wrap">
        <div class="screenshot-bar">
          <div class="sdots"><span class="dr"></span><span class="dy"></span><span class="dg"></span></div>
          <span class="surl">app.turnos.devhub.com.ar</span>
        </div>
        <div class="screenshot-img">
          <img src="/dashboard.png" alt="Panel de administración DevHub Turnos" class="ss-img"/>
        </div>
        <!-- Notif flotante -->
        <div class="ss-notif">
          <div class="nicon"><svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.856L.054 23.285a.75.75 0 0 0 .921.921l5.43-1.478A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.693-.503-5.235-1.382l-.374-.217-3.876 1.054 1.054-3.876-.217-.374A9.953 9.953 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg></div>
          <div><span class="ntit">Nueva reserva recibida</span><span class="nbod">Lucas M. · Detailing Pro · Hoy 09:00 hs</span></div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- RUBROS -->
<section class="rubros">
  <div class="C">
    <p class="rl">Funciona para cualquier negocio con turnos</p>
    <div class="rlist">
      <div class="rc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 3a3 3 0 0 1 3 3v3a3 3 0 0 1-3 3 3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z"/><path d="M18 3a3 3 0 0 1 3 3v3a3 3 0 0 1-3 3 3 3 0 0 1-3-3V6a3 3 0 0 1 3-3z"/><path d="M6 21a3 3 0 0 1 0-6"/><path d="M18 21a3 3 0 0 0 0-6"/><line x1="12" y1="12" x2="12" y2="21"/></svg>Barberías</div>
      <div class="rc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M19 17H5a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2z"/><circle cx="7" cy="17" r="2"/><circle cx="17" cy="17" r="2"/></svg>Detailing</div>
      <div class="rc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>Estética</div>
      <div class="rc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>Médicos</div>
      <div class="rc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="5" r="2"/><path d="M8 22v-5l-3-5 3-3 4 3 4-3 3 3-3 5v5"/></svg>Pilates / Yoga</div>
      <div class="rc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 5.172C10 3.782 8.423 2.679 6.5 3c-2.823.47-4.113 6.006-4 7 .08.703 1.725 1.722 3.656 1 1.261-.472 1.96-1.45 2.344-2.5"/><path d="M14.267 5.172c0-1.39 1.577-2.493 3.5-2.172 2.823.47 4.113 6.006 4 7-.08.703-1.725 1.722-3.656 1-1.261-.472-1.855-1.45-2.239-2.5"/><path d="M8 14v.5"/><path d="M16 14v.5"/><path d="M11.25 16.25h1.5L12 17l-.75-.75z"/><path d="M4.42 11.247A13.152 13.152 0 0 0 4 14.556C4 18.728 7.582 21 12 21s8-2.272 8-6.444c0-1.061-.162-2.2-.493-3.309m-9.243-6.082A8.801 8.801 0 0 1 12 5c.78 0 1.5.108 2.161.306"/></svg>Veterinarias</div>
      <div class="rc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M5.5 8.5 9 12l-3.5 3.5L2 12l3.5-3.5z"/><path d="m12 2-3.5 3.5 3.5 3.5 3.5-3.5z"/><path d="M18.5 8.5 15 12l3.5 3.5L22 12l-3.5-3.5z"/><path d="m12 22-3.5-3.5 3.5-3.5 3.5 3.5z"/></svg>Peluquerías</div>
      <div class="rc"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2a4 4 0 0 1 4 4c0 1.5-.5 2.5-1 3.5-.5 1-1 2-1 3.5 0 2 0 4-2 4s-2-2-2-4c0-1.5-.5-2.5-1-3.5C8.5 8.5 8 7.5 8 6a4 4 0 0 1 4-4z"/></svg>Odontología</div>
    </div>
  </div>
</section>

<!-- FUNCIONES -->
<section id="funciones" class="sec">
  <div class="C">
    <div class="sh center">
      <span class="stag">Funcionalidades</span>
      <h2 class="sh2">Todo lo que necesitás<br/><span class="acc">en un solo sistema</span></h2>
      <p class="sdesc">Sin apps extra. Sin complicaciones. DevHub Turnos centraliza la gestión de turnos de forma profesional.</p>
    </div>
    <div class="fgrid">
      {features.map((f, i) => {
        const icons = [
          `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
          `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
          `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
          `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
          `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>`,
          `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
        ];
        return (
          <div class="fc">
            <div class="ficon"><Fragment set:html={icons[i]}/></div>
            <h3 class="ftit">{f.titulo}</h3>
            <p class="fdesc">{f.desc}</p>
          </div>
        );
      })}
    </div>
  </div>
</section>

<!-- DEMOS -->
<section id="demos" class="sec dark">
  <div class="C">
    <div class="sh center">
      <span class="stag">Demos en vivo</span>
      <h2 class="sh2">Mirá cómo funciona<br/><span class="acc">en cada rubro</span></h2>
      <p class="sdesc">Cada demo es un sitio real con reservas funcionando. Hacé click para verlo en acción.</p>
    </div>
    <div class="dgrid">
      {demos.map(d => (
        <div class={`dc ${!d.live ? "dsoon" : ""}`}>
          <div class="dhead">
            <div class="dprev"><svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg></div>
            <span class={`dbadge ${d.live ? "dlive" : "dwait"}`}>{d.live && <span class="ldot"></span>}{d.live ? "Disponible" : "Próximamente"}</span>
          </div>
          <h3 class="dnom">{d.nombre}</h3>
          <p class="ddesc">{d.desc}</p>
          <div class="dfoot">
            {d.live
              ? <a href={d.url} target="_blank" class="dcta">Ver demo en vivo <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></a>
              : <a href={`${WA_URL}&text=Hola!%20Quiero%20que%20me%20avisen%20cuando%20esté%20el%20demo%20de%20${encodeURIComponent(d.nombre)}`} target="_blank" class="davise">
                  <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.856L.054 23.285a.75.75 0 0 0 .921.921l5.43-1.478A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.693-.503-5.235-1.382l-.374-.217-3.876 1.054 1.054-3.876-.217-.374A9.953 9.953 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
                  Avisame cuando esté
                </a>
            }
          </div>
        </div>
      ))}
    </div>
    <div class="dcta-row">
      <p>¿Tenés un rubro diferente? Consultanos y armamos tu demo.</p>
      <a href={WA_URL} target="_blank" class="bo">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.127.558 4.122 1.532 5.856L.054 23.285a.75.75 0 0 0 .921.921l5.43-1.478A11.945 11.945 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22c-1.907 0-3.693-.503-5.235-1.382l-.374-.217-3.876 1.054 1.054-3.876-.217-.374A9.953 9.953 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/></svg>
        Consultar por WhatsApp
      </a>
    </div>
  </div>
</section>

<!-- PLANES -->
<section id="planes" class="sec">
  <div class="C">
    <div class="sh center">
      <span class="stag">Precios</span>
      <h2 class="sh2">Simple y transparente</h2>
      <p class="sdesc">Sin costos ocultos. Sin comisiones por reserva. Un precio fijo por mes.</p>
    </div>

    <!-- Toggle mensual/anual -->
    <div class="toggle-wrap">
      <span class="tl" id="tlabel-m">Mensual</span>
      <button class="toggle" id="billing-toggle" aria-label="Cambiar facturación">
        <span class="toggle-thumb"></span>
      </button>
      <span class="tl" id="tlabel-a">Anual <span class="badge-off">20% OFF</span></span>
    </div>

    <div class="pgrid">
